# Application
APP_NAME=EDUstell
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8080

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/edustell
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/edustell

# Logging / observability
RUST_LOG=info,api=debug,infrastructure=info
LOG_FORMAT=pretty

# JWT secrets
# Replace with long random values. In production use different secrets and do not commit them.
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_ACCESS_TTL_SECS=900
JWT_REFRESH_TTL_SECS=2592000

# Local docker-compose postgres only
POSTGRES_DB=edustell
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
